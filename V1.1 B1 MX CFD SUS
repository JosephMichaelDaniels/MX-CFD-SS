  // ── KPI strip ────────────────────────────────
  const gfa=vn('gfa');
  document.getElementById('ksGIA').textContent=gia.toLocaleString();
  document.getElementById('ksNIA').textContent=totalNIA.toLocaleString();
  document.getElementById('ksNTG').textContent=ntg.toFixed(0)+'%';

  // ── Value calcs (live) ───────────────────────
  const rent1=vn('rent1b'),rent2=vn('rent2b');
  const grossRent=u1*rent1+u2*rent2;
  const opexPct=vn('opex')/100;
  const noi=grossRent*(1-opexPct);
  const capR=vn('capRate')/100;
  const gcv=capR>0?noi/capR:0;
  const purC=vn('purCosts')/100;
  const ndv=gcv*(1-purC);

  const buildCost=vn('buildCost'),profF=vn('profFees')/100,dmF=vn('dmFee')/100,cont=vn('contingency')/100;
  const totalBuild=gia*buildCost;
  const fees=totalBuild*profF;
  const dm=totalBuild*dmF;
  const ctg=totalBuild*cont;
  const s106=vn('s106')*total;
  const totalCost=totalBuild+fees+dm+ctg+s106/1e6;
  const residual=ndv/1e6-totalCost;
  const poc=totalCost>0?residual/totalCost*100:0;

  document.getElementById('ksGDV').textContent='£'+(ndv/1e6).toFixed(2)+'m';

  // Update 3D building
  buildBuilding();
  updateHUD();

  // Update validation if sim done
  if(simDone&&R){
    // Recompute R with new inputs and refresh results
    R=compute();
    renderEnergyResults(R);
    renderSocialResults(R);
    buildThermal();buildPressure();
  }
}

