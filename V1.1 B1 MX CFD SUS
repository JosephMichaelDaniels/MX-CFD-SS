function velToColor(t){if(t<.25){const f=t/.25;return[0,f,1];}if(t<.5){const f=(t-.25)/.25;return[0,1,1-f];}if(t<.75){const f=(t-.5)/.25;return[f,1,0];}const f=(t-.75)/.25;return[1,1-f*.7,0];}

// ── BUILD BUILDING ────────────────────────────────
function buildBuilding(){
  bGroup.clear();thermalGroup.clear();pressureGroup.clear();bMesh=null;glazeMeshes=[];
  const stor=vn('storeys'),gfH=vn('gfH'),typH=vn('typH');
  const len=vn('length'),dep=vn('depth'),gp=vn('glazPct')/100;
  const H=gfH+(stor-1)*typH;

  // Main body — concrete/masonry shell behind facade
  const bGeo=new THREE.BoxGeometry(len,H,dep);
  const bMat=new THREE.MeshStandardMaterial({color:0x1A3040,roughness:.55,metalness:.25,transparent:true,opacity:.95});
  const b=new THREE.Mesh(bGeo,bMat);b.position.y=H/2;b.castShadow=true;b.receiveShadow=true;bGroup.add(b);bMesh=b;

  // ── PER-FLOOR WINDOW BAY SYSTEM ──────────────────
  // Calculates genuine window-to-wall ratio by creating
  // spandrel panels (concrete) + glazed strips per floor
  // on both long faces (B1 double-loaded corridor typology)
  //
  // Architecture: 6 bays along 48m length (8m bay width)
  // Each bay: brick/concrete pier + window opening
  // WWR controls height of glazed strip within each floor

  const nBays = 6;                   // 6 structural bays along 48m
  const bayW = len / nBays;          // ~8m bay width
  const pierW = 0.5;                 // concrete pier width
  const winW = bayW - pierW;         // window opening width per bay
  const floorHs = [];                // floor heights array
  floorHs.push(gfH);                 // GF is taller (4.2m)
  for(let f=1;f<stor;f++) floorHs.push(typH); // typical 3.05m

  // Material palette
  const matSpandrel = new THREE.MeshStandardMaterial({color:0x22374A,roughness:.75,metalness:.1});
  const matPier     = new THREE.MeshStandardMaterial({color:0x1C2E3E,roughness:.8,metalness:.05});
  const matGlazF    = new THREE.MeshStandardMaterial({color:0x6BBFE0,roughness:.04,metalness:.92,transparent:true,opacity: Math.max(0.28, 0.22 + gp * 0.5)});
  const matGlazB    = new THREE.MeshStandardMaterial({color:0x4A9ABF,roughness:.06,metalness:.85,transparent:true,opacity: Math.max(0.20, 0.15 + gp * 0.45)});
  const matFrame    = new THREE.MeshStandardMaterial({color:0x334455,roughness:.4,metalness:.7});

  // Spandrel height = floor height × (1 - WWR), but min 0.3m for sill/lintel
  // Window height   = floor height × WWR, capped realistically
  const spandrelRatio = Math.max(0.08, 1 - gp); // never fully disappear
  const windowRatio   = Math.min(gp, 0.92);       // cap at 92% of floor ht

  let yBase = 0;
  floorHs.forEach((fh, fi) => {
    const spH = fh * spandrelRatio;   // spandrel band height
    const wH  = fh * windowRatio;     // window opening height
    const winY = yBase + spH/2 + wH/2; // window centre Y
    const spYbot = yBase + spH/4;       // bottom spandrel Y (sill)
    const spYtop = yBase + fh - spH/4; // top spandrel Y (lintel)

    // Both long faces: +Z (front) and -Z (back)
    [dep/2 + 0.04, -(dep/2 + 0.04)].forEach((faceZ, fi2) => {
      const matG = fi2===0 ? matGlazF : matGlazB;
      const norm = fi2===0 ? 1 : -1;

      // Full-width spandrel band (bottom sill strip)
      const sillMesh = new THREE.Mesh(new THREE.BoxGeometry(len, spH*0.5, 0.18), matSpandrel);
      sillMesh.position.set(0, yBase + spH*0.25, faceZ);
      bGroup.add(sillMesh);

      // Full-width spandrel band (top lintel strip)
      const lintMesh = new THREE.Mesh(new THREE.BoxGeometry(len, spH*0.5, 0.18), matSpandrel);
      lintMesh.position.set(0, yBase + fh - spH*0.25, faceZ);
      bGroup.add(lintMesh);

      // Per-bay: piers + glazing
      for(let b2=0; b2<nBays; b2++){
        const bayX = -len/2 + (b2 + 0.5) * bayW;

        // Vertical pier (skip where cores are — bays 1 and 4)
        const isCoreZone = (b2===1 || b2===4);
        const pierMat2 = isCoreZone
          ? new THREE.MeshStandardMaterial({color:0x142030,roughness:.85})
          : matPier;
        const pier = new THREE.Mesh(new THREE.BoxGeometry(pierW, fh, 0.22), pierMat2);
        pier.position.set(bayX - bayW/2 + pierW/2, yBase + fh/2, faceZ);
        bGroup.add(pier);

        // Window glazing panel
        if(!isCoreZone && wH > 0.15){
          // Window panel
          const win = new THREE.Mesh(new THREE.BoxGeometry(winW - 0.06, wH - 0.08, 0.06), matG);
          win.position.set(bayX + pierW/4, winY, faceZ + norm*0.04);
          bGroup.add(win);
          glazeMeshes.push(win);

          // Thin aluminium window frame
          if(gp > 0.15){
            const frameH = new THREE.Mesh(new THREE.BoxGeometry(winW, 0.06, 0.08), matFrame);
            frameH.position.set(bayX + pierW/4, winY + wH/2 - 0.03, faceZ);
            bGroup.add(frameH);
            const frameH2 = frameH.clone();
            frameH2.position.y = winY - wH/2 + 0.03;
            bGroup.add(frameH2);
            const frameV = new THREE.Mesh(new THREE.BoxGeometry(0.06, wH, 0.08), matFrame);
            frameV.position.set(bayX + pierW/4 - winW/2 + 0.03, winY, faceZ);
            bGroup.add(frameV);
            const frameV2 = frameV.clone();
            frameV2.position.x = bayX + pierW/4 + winW/2 - 0.03;
            bGroup.add(frameV2);
            // Horizontal mullion mid-window (if window tall enough)
            if(wH > 1.4){
              const mull = new THREE.Mesh(new THREE.BoxGeometry(winW, 0.05, 0.08), matFrame);
              mull.position.set(bayX + pierW/4, winY, faceZ);
              bGroup.add(mull);
            }
          }
        }
      }
    });

    yBase += fh;
  });

  // Floor plates (visible as thin bands)
  const plateMat=new THREE.MeshStandardMaterial({color:0x0077AA,roughness:.7});
  // Ground floor plate (4.2m)
  const gfPlate=new THREE.Mesh(new THREE.BoxGeometry(len+.2,.12,dep+.2),plateMat);
  gfPlate.position.y=gfH;bGroup.add(gfPlate);
  // Typical floors
  for(let f=1;f<stor;f++){
    const fp=new THREE.Mesh(new THREE.BoxGeometry(len+.2,.1,dep+.2),plateMat);
    fp.position.y=gfH+f*typH;bGroup.add(fp);
  }

  // Cores (2 cores, internal, at 1/4 and 3/4 along length)
  const coreGeo=new THREE.BoxGeometry(6.5,H+.2,6);
  const coreMat=new THREE.MeshStandardMaterial({color:0x0D2035,roughness:.8});
  [-len/4,len/4].forEach(cx=>{
    const core=new THREE.Mesh(coreGeo,coreMat);core.position.set(cx,H/2,0);bGroup.add(core);
  });

  // Roof parapet
  const rp=new THREE.Mesh(new THREE.BoxGeometry(len+.3,.35,dep+.3),new THREE.MeshStandardMaterial({color:0x1C2E3E,roughness:.85}));
  rp.position.y=H+.18;bGroup.add(rp);

  // PV array on roof
  const pvA=vn('pvArea');
  if(pvA>0){
    const pvW=Math.min(Math.sqrt(pvA*1.6),len-4),pvD=Math.min(pvA/pvW,dep-2);
    const pv=new THREE.Mesh(new THREE.BoxGeometry(pvW,.05,pvD),new THREE.MeshStandardMaterial({color:0x00113A,roughness:.15,metalness:.95}));
    pv.position.set(0,H+.52,0);pv.rotation.x=-.1;bGroup.add(pv);
    const pg=new THREE.GridHelper(Math.min(pvW,pvD)*.88,6,0x0033AA,0x001155);pg.position.set(0,H+.55,0);bGroup.add(pg);
  }

  // Ground floor commercial strip (GF front)
  const comMat=new THREE.MeshStandardMaterial({color:0x1A3520,roughness:.5,metalness:.3,transparent:true,opacity:.7});
  const com=new THREE.Mesh(new THREE.BoxGeometry(len,gfH,dep+.05),comMat);
  com.position.y=gfH/2;bGroup.add(com);
  // Active frontage glazing (GF)
  const agMat=new THREE.MeshStandardMaterial({color:0x99FFCC,roughness:.04,metalness:.8,transparent:true,opacity:.45});
  const ag=new THREE.Mesh(new THREE.BoxGeometry(len*.65,gfH*.7,.06),agMat);
  ag.position.set(0,gfH*.45,dep/2+.07);bGroup.add(ag);

  // Context buildings
  [[-55,0,-20,22,8],[-55,0,18,16,12],[55,0,-15,20,10],[55,0,15,18,6],[0,0,-35,40,5],[0,0,35,36,4]].forEach(([x,,z,w,h])=>{
    const cb=new THREE.Mesh(new THREE.BoxGeometry(w,h,w*.5+2),new THREE.MeshStandardMaterial({color:0x0D1A28,roughness:.85}));
    cb.position.set(x,h/2,z);cb.castShadow=true;bGroup.add(cb);
  });

  updateHUD();applyMode(curMode);
}

// ── VISUAL MODES ─────────────────────────────────
function applyMode(mode){
  cfdPts.visible=false;solPts.visible=false;dayPts.visible=false;
  thermalGroup.visible=false;pressureGroup.visible=false;
  document.getElementById('cfdLeg').style.display='none';
  sun.intensity=2.8;

  const labels={massing:'MASSING · B1 CROMPTON',thermal:'THERMAL HEAT LOSS',cfd:'CFD WIND · VELOCITY',solar:'SOLAR GAIN',daylight:'DAYLIGHT SIMULATION'};
  document.getElementById('modeLabel').textContent=labels[mode]||mode.toUpperCase();
  if(!bMesh)return;
  const m=bMesh.material;
  m.emissive.set(0);

  if(mode==='massing'){m.color.set(0x1a3a5c);m.opacity=.9;}
  else if(mode==='thermal'){
    if(!simDone)return;
    m.color.set(0x0D1A2A);m.opacity=.4;thermalGroup.visible=true;
  }else if(mode==='cfd'){
    if(!simDone)return;
    m.color.set(0x0A1E2E);m.opacity=.55;
    cfdPts.visible=true;pressureGroup.visible=true;
    document.getElementById('cfdLeg').style.display='flex';
  }else if(mode==='solar'){
    if(!simDone)return;
    m.color.set(0x1A2A1A);m.opacity=.5;
    // Tint glazing panels amber — intensity scales with WWR
    const gp2=vn('glazPct')/100;
    glazeMeshes.forEach(g=>{
      if(g.material){
        g.material.color.set(0xFFAA22);
        g.material.opacity=Math.min(0.75, 0.3 + gp2*0.45);
        g.material.emissive=new THREE.Color(0x331100);
        g.material.emissiveIntensity=0.3*gp2;
      }
    });
    solPts.visible=true;sun.intensity=4.5+gp2*1.5;
  }else if(mode==='daylight'){
    if(!simDone)return;
    m.color.set(0x162232);m.opacity=.6;
    const gp3=vn('glazPct')/100;
    glazeMeshes.forEach(g=>{
      if(g.material){
        g.material.color.set(0xCCEEFF);
        g.material.opacity=Math.min(0.75, 0.25 + gp3*0.5);
        g.material.emissive=new THREE.Color(0x001122);
        g.material.emissiveIntensity=0.2*gp3;
      }
    });
    dayPts.visible=true;sun.intensity=3.5;
  }
}

function buildThermal(){
  thermalGroup.clear();if(!bMesh||!R)return;
  const wU=vn('wallU'),len=vn('length'),dep=vn('depth'),H=bMesh.position.y*2;
  const faces=[{w:len,h:H,px:0,py:H/2,pz:dep/2,ry:0,u:wU},{w:len,h:H,px:0,py:H/2,pz:-dep/2,ry:Math.PI,u:wU},{w:dep,h:H,px:len/2,py:H/2,pz:0,ry:Math.PI/2,u:wU},{w:dep,h:H,px:-len/2,py:H/2,pz:0,ry:-Math.PI/2,u:wU},{w:len,h:dep,px:0,py:H+.15,pz:0,rx:-Math.PI/2,u:vn('roofU')}];
  faces.forEach(f=>{
    const g=new THREE.PlaneGeometry(f.w,f.h,6,6);
    const colors=new Float32Array(g.attributes.position.count*3);
    for(let vi=0;vi<g.attributes.position.count;vi++){
      const t=Math.min(f.u/.5,1);const h2=(1-t)*.66;
      const c=new THREE.Color().setHSL(h2,1,.55);
      colors[vi*3]=c.r;colors[vi*3+1]=c.g;colors[vi*3+2]=c.b;
    }
    g.setAttribute('color',new THREE.BufferAttribute(colors,3));
    const mesh=new THREE.Mesh(g,new THREE.MeshBasicMaterial({vertexColors:true,transparent:true,opacity:.7,side:THREE.FrontSide,depthWrite:false}));
    mesh.position.set(f.px,f.py,f.pz);if(f.ry)mesh.rotation.y=f.ry;if(f.rx)mesh.rotation.x=f.rx;
    thermalGroup.add(mesh);
  });
}
function buildPressure(){
  pressureGroup.clear();if(!R)return;
  const len=vn('length'),dep=vn('depth'),H=bMesh?bMesh.position.y*2:18;
  const pFaces=[{w:dep,h:H,px:len/2,py:H/2,pz:0,ry:Math.PI/2,cp:.8,col:0xFF6600},{w:dep,h:H,px:-len/2,py:H/2,pz:0,ry:-Math.PI/2,cp:-.5,col:0x0044CC},{w:len,h:H,px:0,py:H/2,pz:dep/2,ry:0,cp:-.7,col:0x002288},{w:len,h:H,px:0,py:H/2,pz:-dep/2,ry:Math.PI,cp:-.7,col:0x002288}];
  pFaces.forEach(f=>{
    const t=(f.cp+.8)/1.6;const col=new THREE.Color();col.setHSL(t<.4?.66:t*.12,1,.5);
    const mesh=new THREE.Mesh(new THREE.PlaneGeometry(f.w,f.h),new THREE.MeshBasicMaterial({color:col,transparent:true,opacity:.42,side:THREE.FrontSide,depthWrite:false}));
    mesh.position.set(f.px,f.py,f.pz);if(f.ry)mesh.rotation.y=f.ry;pressureGroup.add(mesh);
  });
}

