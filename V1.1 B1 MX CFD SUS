        else if(Math.abs(z)>bW-.5&&Math.abs(z)<bW+2.5){vx*=1.5;}
        if(y>bH-.5&&y<bH+2.5&&Math.abs(z)<bW&&x>-bL&&x<bL){vx*=1.4;vy+=.015;}
      }
      x+=vx;y+=vy;z+=vz;
      if(x>34||y>32){x=-30;y=Math.random()*26+.5;z=(Math.random()-.5)*vn('depth')*2;cfdSpd[i]=.08+Math.random()*.12;}
