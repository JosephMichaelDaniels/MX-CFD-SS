// ══════════════════════════════════════════════════
// CALCULATION ENGINE
// ══════════════════════════════════════════════════
const CLIMATE={HDD:2400,CDD:180,Tdes_w:-3,Tdes_s:30,solar:950,wind:4.5};
const COP={'ASHP (COP 3.5)':3.5,'GSHP (COP 4.2)':4.2,'Gas Boiler (η 92%)':0.92,'District Heat':1.1};
const VE={'MVHR 85%':0.85,'CAV No Recovery':0.0,'Natural Ventilation':0.0};
const HABPRE={'Brownfield/Urban':.5,'Grassland Low Dist.':1.8,'Grassland Medium':2.8,'Arable':.9};
const HABPOST={'Urban/Landscaped':2.1,'Species-rich Grassland':3.6,'Wildflower Meadow':4.2,'Woodland':6.0};

function compute(){
  const gia=vn('gia'),gfa=vn('gfa'),resNIA=vn('resNIA'),comNIA=vn('comNIA');
  const totalNIA=resNIA+comNIA,ntgVal=gia>0?totalNIA/gia:0;
  const stor=vn('storeys'),gfH=vn('gfH'),typH=vn('typH'),len=vn('length'),dep=vn('depth');
  const H=gfH+(stor-1)*typH,gp=vn('glazPct')/100;
  const wU=vn('wallU'),glazU_=vn('glazU'),roofU_=vn('roofU'),ap=vn('airPerm');
  const psi=0.04;
  const shgc=0.35;
  const total=vn('totalUnits'),u1=vn('u1b'),u2=vn('u2b');

  // Geometry
  const wallA=2*(len+dep)*H,glazA=wallA*gp,opaqueA=wallA-glazA,roofA=len*dep,floorA=len*dep;

  // Heat loss — EN ISO 13790
  const htW=opaqueA*wU,htG=glazA*glazU_,htR=roofA*roofU_,htF=floorA*.22,htTB=2*(len+dep)*stor*psi;
  const htFab=htW+htG+htR+htF+htTB;
  const vol=gia*((gfH+typH)/2);// weighted avg
  const hInf=vol*(ap/20)*0.34;
  const veEff=VE[vs('vent')]??0;
  const hVent=vol*.8*.34*(1-veEff);// residential ACH 0.8
  const htTot=htFab+hInf+hVent;

  // Internal gains
  const nPpl=resNIA/25;// residential 25m²/p
  const qOcc=nPpl*70;const qLi=gia*5;const qEq=gia*8;const qInt=qOcc+qLi+qEq;
  const gv=shgc*.9,ff=.7,sh=.6;// mixed orientation residential
  const qSol=glazA*ff*gv*CLIMATE.solar*sh;
  const dTh=21-CLIMATE.Tdes_w,dTc=CLIMATE.Tdes_s-24;
  const qHp=htTot*dTh/1000,qCp=(htTot*dTc+qInt+qSol/8760)/1000;
  const qHyr=Math.max((htTot*CLIMATE.HDD*24)/1000-qInt*.95*5500/1000-qSol/1000*.4,40);
  const qCyr=Math.max((htTot*CLIMATE.CDD*24+qInt*.6*1800)/1000+qSol*.2/1000,10);

  const cop=COP[vs('heating')]||3.5;const eer=3.8;
  const eH=qHyr/cop,eC=qCyr/eer,eLi=gia*5*2000/1000,eEq=gia*8*2200/1000,eVn=vol*.8*.4*3000/1e6;
  const pvG=vn('pvArea')*CLIMATE.solar*.18/1000;
  const eTot=eH+eC+eLi+eEq+eVn,eNet=Math.max(0,eTot-pvG);
  const EUI=eTot/gia,EUInet=eNet/gia;
  let epc='F';if(EUInet<30)epc='A+';else if(EUInet<50)epc='A';else if(EUInet<75)epc='B';else if(EUInet<100)epc='C';else if(EUInet<135)epc='D';else if(EUInet<175)epc='E';

  // CFD
  const ws=CLIMATE.wind,dq=.5*1.225*ws**2,cpW=.8,cpL=-.5,mxV=ws*1.8,drg=dq*(cpW-cpL)*wallA/1000,achW=(ap/20)*Math.pow(ws/4,.67);

  // Monthly
  const mH=[],mC=[];const hF=[1.4,1.3,1.0,.6,.2,.0,.0,.0,.1,.4,.9,1.3],cF=[.0,.0,.0,.1,.4,.9,1.2,1.1,.6,.2,.0,.0];
  for(let m=0;m<12;m++){mH.push(Math.round(qHyr/12*hF[m]*1.5));mC.push(Math.round(qCyr/12*cF[m]*2.2));}

  // Value calcs
  const rent1=vn('rent1b'),rent2=vn('rent2b');
  const grossRent=u1*rent1+u2*rent2;
  const opexPct=vn('opex')/100,noi=grossRent*(1-opexPct);
  const capR=vn('capRate')/100,gcv=capR>0?noi/capR:0;
  const purC=vn('purCosts')/100,ndv=gcv*(1-purC);
  const buildCostSqm=vn('buildCost'),profF=vn('profFees')/100,dmF=vn('dmFee')/100,cont=vn('contingency')/100;
  const totalBuild=gia*buildCostSqm,fees=totalBuild*profF,dm=totalBuild*dmF,ctg=totalBuild*cont;
  const s106=vn('s106')*total;
  const totalCost=(totalBuild+fees+dm+ctg+s106)/1e6;
  const residual=ndv/1e6-totalCost;
  const poc=totalCost>0?residual/totalCost*100:0;

  // Social — T1
  const greenSp=vn('greenSpace');
  const residents=Math.round(resNIA/25);
  const greenPP=residents>0?+(greenSp/residents).toFixed(1):0;
  const preU=(HABPRE[vs('habPre')]||.5)*(greenSp/10000);
  const postU=(HABPOST[vs('habPost')]||2.1)*(greenSp/10000);
  const bngPct=preU>0?+((postU/preU-1)*100).toFixed(1):110;
  const trees=Math.round(greenSp/25);
  const affordable=Math.round(total*.2);
  const renMwh=pvG;
  // T1/2
  const constCostM=totalBuild/1e6;
  const constJobs=Math.round(constCostM*3);
  const apprent=Math.round(constJobs*.02);
  const localSpend=+(constCostM*.30).toFixed(2);
  const trainHrs=constJobs*5;
  const embodied=vn('embodied');
  // T3
  const crremActual=+(EUI*.136).toFixed(2);
  const crremT2030=12.8;
  const pcafScore=2;
  const jobsFTE=Math.round(comNIA/20);
  const bizRates=+((Math.round(comNIA/100)*50000*.512)/1e6).toFixed(3);
  const fmSupply=+(comNIA*30/1e6).toFixed(3);
  const nzbs=EUInet<=30?'Platinum':EUInet<=55?'Gold':EUInet<=80?'Silver':EUInet<=100?'Bronze':'In Progress';
  // Score
  const t1Score=Math.min(100,Math.round((total>0?20:0)+(bngPct>=10?25:15)+(greenPP>=9?20:greenPP>=5?12:5)+(vn('evPts')>0?15:0)+(vn('battery')>0?10:0)+(renMwh>0?10:0)));
  const t2Score=Math.min(100,Math.round((constJobs>0?30:0)+(embodied<500?25:embodied<700?15:5)+(apprent>0?15:0)+(trees>0?15:0)+(vn('floodInv')>0?15:0)));
  const t3Score=Math.min(100,Math.round((crremActual<=crremT2030?30:crremActual<=20?18:8)+(jobsFTE>0?20:0)+(EUI<100?20:EUI<140?12:5)+(pcafScore<=2?15:10)+(nzbs==='Gold'||nzbs==='Platinum'?15:nzbs==='Silver'?10:5)));
  const overallScore=Math.round(t1Score*.3+t2Score*.3+t3Score*.4);

  const maxLoad=htFab*dTh/1000+hInf*dTh/1000+hVent*dTh/1000+qSol/8760/1000+qInt/1000;

  return{
    gia,gfa,resNIA,comNIA,totalNIA,ntgVal,stor,gfH,typH,len,dep,H,gp,
    wallA,glazA,opaqueA,roofA,wU,glazU_,roofU_,ap,psi,shgc,
    htW,htG,htR,htF,htTB,htFab,hInf,hVent,htTot,
    qOcc,qLi,qEq,qInt,qSol,qHp,qCp,qHyr,qCyr,
    eH,eC,eLi,eEq,eVn,eTot,pvG,eNet,EUI,EUInet,epc,
    mxV,dq,cpW,cpL,drg,achW,monthly:{h:mH,c:mC},
    cop,eer,maxLoad,
    grossRent,noi,gcv,ndv,totalBuild,fees,dm,ctg,s106,totalCost,residual,poc,
    greenSp,residents,greenPP,bngPct,trees,affordable,renMwh,
    constCostM,constJobs,apprent,localSpend,trainHrs,embodied,total,u1,u2,
    crremActual,crremT2030,pcafScore,jobsFTE,bizRates,fmSupply,nzbs,
    t1Score,t2Score,t3Score,overallScore,
    opexPct,rent1,rent2,buildCostSqm,
  };
}

