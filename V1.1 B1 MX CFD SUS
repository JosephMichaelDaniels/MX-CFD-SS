<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>MetaConnex · B1 Crompton Place · Performance Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap');
:root{
  --bg:#060A0F;--panel:#0D1520;--panel2:#111C2E;--b:#1A2A40;
  --a:#00C8FF;--a2:#00FF88;--a3:#FF6B35;--a4:#C850C0;
  --gold:#C8963C;--teal:#00CCBB;
  --txt:#E2EBF6;--mut:#5A7A9A;--red:#FF4444;--yel:#FFD700;
  --t1:#00C8FF;--t2:#00FF88;--t3:#C8963C;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--txt);font-family:'DM Sans',sans-serif;font-size:12px;height:100vh;overflow:hidden;display:flex;flex-direction:column;}
::-webkit-scrollbar{width:3px;height:3px;}::-webkit-scrollbar-thumb{background:var(--b);}

/* ── TOPBAR ── */
.topbar{height:44px;background:var(--panel);border-bottom:1px solid var(--b);display:flex;align-items:center;padding:0 14px;gap:12px;flex-shrink:0;}
.logo{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:3px;color:var(--a);display:flex;align-items:center;gap:7px;}
.logo-dot{width:6px;height:6px;background:var(--a2);border-radius:50%;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.proj-tag{font-family:'Space Mono',monospace;font-size:10px;color:var(--txt);background:rgba(0,200,255,.1);border:1px solid rgba(0,200,255,.25);padding:3px 10px;letter-spacing:1px;}
.topbar-right{margin-left:auto;display:flex;gap:7px;align-items:center;}
.badge{font-size:9px;font-family:'Space Mono',monospace;background:rgba(0,200,255,.08);color:var(--a);border:1px solid rgba(0,200,255,.22);padding:2px 8px;letter-spacing:.5px;}
.badge.g{background:rgba(0,255,136,.08);color:var(--a2);border-color:rgba(0,255,136,.22);}
.badge.o{background:rgba(255,107,53,.08);color:var(--a3);border-color:rgba(255,107,53,.22);}
.badge.gold{background:rgba(200,150,60,.08);color:var(--gold);border-color:rgba(200,150,60,.22);}

/* ── MODULE TABS ── */
.module-tabs{display:flex;background:var(--panel);border-bottom:1px solid var(--b);flex-shrink:0;}
.mtab{padding:9px 22px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border-right:1px solid var(--b);color:var(--mut);transition:all .2s;position:relative;}
.mtab.active{color:var(--txt);background:rgba(0,200,255,.05);}
.mtab.active::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--a);}
.mtab.social.active::after{background:var(--a2);}
.mtab:hover:not(.active){color:var(--txt);}

/* ── MAIN LAYOUT ── */
.main{display:flex;flex:1;overflow:hidden;}

/* ── LEFT: BUILDING EDITOR ── */
.editor{width:260px;background:var(--panel);border-right:1px solid var(--b);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0;}
.esec{border-bottom:1px solid var(--b);padding:10px 12px;}
.esh{font-size:9px;font-family:'Space Mono',monospace;color:var(--mut);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:5px;}
.esh::before{content:'';width:8px;height:1px;background:var(--a);}
.esh.g::before{background:var(--a2);}
.esh.o::before{background:var(--a3);}
.esh.gold::before{background:var(--gold);}

/* inline editable fields */
.field{display:flex;align-items:center;gap:5px;margin-bottom:5px;position:relative;}
.flbl{flex:1;color:var(--mut);font-size:11px;}
.fval{width:85px;background:var(--panel2);border:1px solid var(--b);color:var(--txt);padding:4px 7px;font-family:'Space Mono',monospace;font-size:11px;border-radius:2px;text-align:right;outline:none;transition:border-color .2s;}
.fval:focus{border-color:var(--a);}
.fval.live{border-color:var(--a3);color:var(--a3);animation:flash .4s ease;}
@keyframes flash{0%{background:rgba(255,107,53,.15)}100%{background:transparent}}
.fval[readonly]{color:var(--mut);background:transparent;border-color:transparent;cursor:default;}
.funit{font-size:9px;color:var(--mut);width:26px;flex-shrink:0;}
.derived-badge{font-size:8px;font-family:'Space Mono',monospace;color:var(--teal);background:rgba(0,204,187,.08);border:1px solid rgba(0,204,187,.2);padding:1px 4px;margin-left:auto;flex-shrink:0;}

select.fval{text-align:left;cursor:pointer;}
option{background:#0D1520;}

.calc-note{font-size:9px;color:var(--mut);font-family:'Space Mono',monospace;line-height:1.5;margin-top:3px;padding:4px 6px;background:rgba(0,0,0,.2);border-radius:2px;}

/* live KPI strip below editor header */
.kpi-strip{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:8px;}
.ks{background:var(--panel2);border:1px solid var(--b);padding:7px 8px;border-radius:2px;}
.ks-l{font-size:8px;font-family:'Space Mono',monospace;color:var(--mut);letter-spacing:.5px;text-transform:uppercase;margin-bottom:2px;}
.ks-v{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;line-height:1;}
.ks-v.a{color:var(--a)}.ks-v.g{color:var(--a2)}.ks-v.o{color:var(--a3)}.ks-v.gold{color:var(--gold)}
.ks-u{font-size:8px;color:var(--mut);}

.run-btn{width:100%;padding:9px;background:var(--a2);color:var(--bg);border:none;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;cursor:pointer;font-weight:700;margin-top:5px;transition:all .2s;}
.run-btn:hover{background:transparent;color:var(--a2);border:1px solid var(--a2);}

/* ── VIEWPORT ── */
.viewport{flex:1;position:relative;overflow:hidden;background:#040810;}
#threeCanvas{display:block;width:100%;height:100%;}
.vp-corners .c{position:absolute;width:16px;height:16px;border-color:rgba(0,200,255,.35);border-style:solid;}
.c.tl{top:12px;left:12px;border-width:1px 0 0 1px}.c.tr{top:12px;right:12px;border-width:1px 1px 0 0}
.c.bl{bottom:12px;left:12px;border-width:0 0 1px 1px}.c.br{bottom:12px;right:12px;border-width:0 1px 1px 0}
.mode-label{position:absolute;top:12px;left:12px;font-family:'Space Mono',monospace;font-size:8px;letter-spacing:2px;color:var(--a);background:rgba(6,10,15,.85);border:1px solid rgba(0,200,255,.25);padding:3px 9px;text-transform:uppercase;pointer-events:none;}
.vp-hud{position:absolute;top:12px;left:50%;transform:translateX(-50%);display:flex;gap:10px;pointer-events:none;}
.hud{background:rgba(6,10,15,.88);border:1px solid var(--b);padding:4px 10px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--mut);display:flex;gap:6px;}
.hud span{color:var(--txt);}
.sim-tabs{position:absolute;bottom:12px;left:50%;transform:translateX(-50%);display:flex;gap:2px;pointer-events:all;background:rgba(6,10,15,.92);border:1px solid var(--b);padding:3px;}
.stab{padding:4px 12px;font-size:8px;font-family:'Space Mono',monospace;letter-spacing:1px;color:var(--mut);cursor:pointer;transition:all .2s;border:1px solid transparent;text-transform:uppercase;}
.stab.active{color:var(--a);border-color:rgba(0,200,255,.3);background:rgba(0,200,255,.08);}
.cfd-legend{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:rgba(6,10,15,.88);border:1px solid var(--b);padding:8px 7px;flex-direction:column;align-items:center;gap:3px;display:none;}
.leg-bar{width:11px;height:110px;border:1px solid var(--b);}
.leg-ticks{display:flex;flex-direction:column;justify-content:space-between;height:110px;}
.leg-tick{font-size:7px;font-family:'Space Mono',monospace;color:var(--mut);}
.leg-lbl{font-size:7px;font-family:'Space Mono',monospace;color:var(--mut);letter-spacing:1px;}
/* SIM OVERLAY */
.sim-ov{position:absolute;inset:0;background:rgba(4,8,16,.82);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;z-index:50;opacity:0;pointer-events:none;transition:opacity .25s;backdrop-filter:blur(2px);}
.sim-ov.on{opacity:1;pointer-events:all;}
.spinner{width:38px;height:38px;border:2px solid var(--b);border-top-color:var(--a2);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
.sim-lbl{font-family:'Space Mono',monospace;font-size:10px;color:var(--a2);letter-spacing:2px;}
.sim-step-txt{font-size:9px;color:var(--mut);letter-spacing:1px;}
.prog-wrap{width:200px;}
.prog-trk{height:2px;background:var(--panel2);border-radius:2px;overflow:hidden;margin-bottom:5px;}
.prog-f{height:100%;background:linear-gradient(90deg,var(--a2),var(--a));border-radius:2px;transition:width .2s;}
.prog-lb{display:flex;justify-content:space-between;font-family:'Space Mono',monospace;font-size:8px;color:var(--mut);}

/* ── RIGHT: RESULTS ── */
.results{width:280px;background:var(--panel);border-left:1px solid var(--b);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0;}
.rph{font-size:9px;font-family:'Space Mono',monospace;color:var(--mut);letter-spacing:2px;text-transform:uppercase;padding:10px 11px 6px;border-bottom:1px solid var(--b);flex-shrink:0;}

/* results panels */
.rpanel{display:none;flex-direction:column;flex:1;}
.rpanel.active{display:flex;}

.kgrid{display:grid;grid-template-columns:1fr 1fr;gap:5px;padding:8px;}
.kcard{background:var(--panel2);border:1px solid var(--b);padding:8px;border-radius:2px;position:relative;overflow:hidden;}
.kcard::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;}
.kcard.b::after{background:var(--a)}.kcard.g::after{background:var(--a2)}.kcard.o::after{background:var(--a3)}.kcard.p::after{background:var(--a4)}.kcard.gold::after{background:var(--gold)}
.kl{font-size:8px;color:var(--mut);letter-spacing:.5px;text-transform:uppercase;margin-bottom:3px;}
.kv{font-family:'Space Mono',monospace;font-size:15px;font-weight:700;line-height:1;}
.kv.b{color:var(--a)}.kv.g{color:var(--a2)}.kv.o{color:var(--a3)}.kv.p{color:var(--a4)}.kv.gold{color:var(--gold)}
.ku{font-size:8px;color:var(--mut);margin-top:1px;}.kd{font-size:8px;color:var(--a2);margin-top:2px;}.kd.na{color:var(--mut);}

/* value strip */
.val-strip{margin:0 8px 6px;background:var(--panel2);border:1px solid var(--b);padding:8px 10px;border-radius:2px;}
.val-strip .kl{margin-bottom:4px;}
.val-row{display:flex;align-items:baseline;gap:8px;}

/* bar rows */
.section-hdr{font-size:9px;color:var(--mut);font-family:'Space Mono',monospace;letter-spacing:1px;text-transform:uppercase;padding:8px 11px 5px;}
.bar-rows{padding:0 11px 8px;}
.br{display:flex;align-items:center;gap:6px;margin-bottom:4px;}
.brl{width:72px;font-size:9px;color:var(--mut);flex-shrink:0;}
.brt{flex:1;height:4px;background:var(--panel2);border-radius:1px;overflow:hidden;}
.brf{height:100%;border-radius:1px;transition:width .8s ease;}
.brv{width:48px;font-family:'Space Mono',monospace;font-size:9px;text-align:right;color:var(--txt);flex-shrink:0;}

/* monthly chart */
canvas.chart{width:100%;display:block;}
.chart-wrap{padding:0 11px 8px;}

/* cfd grid */
.cfd-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;padding:0 11px 8px;}
.cc{background:var(--panel2);border:1px solid var(--b);padding:7px;}
.ccl{font-size:8px;color:var(--mut);letter-spacing:.5px;text-transform:uppercase;margin-bottom:2px;}
.ccv{font-family:'Space Mono',monospace;font-size:11px;}
.ccv.a{color:var(--a)}.ccv.o{color:var(--a3)}.ccv.g{color:var(--a2)}

/* validation list */
.val-list{padding:0 11px;}
.vi{display:flex;align-items:flex-start;gap:6px;padding:5px 0;border-bottom:1px solid var(--b);}
.vi:last-child{border-bottom:none;}
.vic{width:14px;height:14px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:7px;flex-shrink:0;margin-top:1px;}
.vic.pass{background:rgba(0,255,136,.18);color:var(--a2);}
.vic.warn{background:rgba(255,215,0,.12);color:var(--yel);}
.vic.fail{background:rgba(255,68,68,.12);color:var(--red);}
.vit{flex:1;}.vn{font-size:10px;font-weight:500;margin-bottom:1px;}.vd{font-size:9px;color:var(--mut);}.vs{font-size:8px;font-family:'Space Mono',monospace;color:var(--mut);margin-top:1px;}

/* social metric cards */
.smgrid{display:grid;grid-template-columns:1fr 1fr;gap:5px;padding:8px;}
.smc{background:var(--panel2);border:1px solid var(--b);padding:8px;border-radius:2px;position:relative;}
.smc::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;}
.smc.t1::before{background:var(--t1)}.smc.t2::before{background:var(--t2)}.smc.t3::before{background:var(--t3)}
.sml{font-size:8px;color:var(--mut);letter-spacing:.5px;text-transform:uppercase;margin-bottom:2px;}
.smv{font-family:'Space Mono',monospace;font-size:14px;font-weight:700;line-height:1;}
.smv.t1{color:var(--t1)}.smv.t2{color:var(--t2)}.smv.t3{color:var(--t3)}.smv.gold{color:var(--gold)}
.smu{font-size:8px;color:var(--mut);margin-top:1px;}
.smst{font-size:7px;font-family:'Space Mono',monospace;margin-top:3px;}
.smst.pass{color:var(--a2)}.smst.warn{color:var(--yel)}.smst.fail{color:var(--red)}.smst.info{color:var(--a)}

/* export/report area */
.rep-area{padding:10px;border-top:1px solid var(--b);margin-top:auto;flex-shrink:0;}
.exp-btn{width:100%;padding:8px;border:1px solid var(--a);color:var(--a);background:rgba(0,200,255,.06);font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1.5px;cursor:pointer;transition:all .2s;text-transform:uppercase;margin-bottom:4px;}
.exp-btn:hover{background:var(--a);color:var(--bg);}
.exp-btn:disabled{opacity:.3;cursor:not-allowed;}
.exp-btn.social{border-color:var(--a2);color:var(--a2);background:rgba(0,255,136,.06);}
.exp-btn.social:hover{background:var(--a2);color:var(--bg);}
.exp-std{font-size:8px;color:var(--mut);text-align:center;font-family:'Space Mono',monospace;line-height:1.5;}

/* value dashboard section (social results) */
.vdash{margin:0 8px 6px;background:var(--panel2);border:1px solid rgba(200,150,60,.25);padding:9px;border-radius:2px;}
.vdash-title{font-size:9px;font-family:'Space Mono',monospace;color:var(--gold);letter-spacing:1px;text-transform:uppercase;margin-bottom:7px;}
.vd-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid rgba(26,42,64,.5);font-size:10px;}
.vd-row:last-child{border-bottom:none;}
.vd-lbl{color:var(--mut);}
.vd-val{font-family:'Space Mono',monospace;}
.vd-val.pos{color:var(--a2)}.vd-val.neg{color:var(--red)}.vd-val.n{color:var(--txt)}

/* score wheel area */
.score-area{padding:8px 11px;display:flex;align-items:center;gap:12px;}
.score-ring{width:64px;height:64px;flex-shrink:0;}
.score-detail{flex:1;}
.score-main{font-family:'Space Mono',monospace;font-size:28px;font-weight:700;line-height:1;color:var(--gold);}
.score-lbl{font-size:9px;color:var(--mut);font-family:'Space Mono',monospace;letter-spacing:1px;}
.score-bars{margin-top:5px;}
.sb-row{display:flex;align-items:center;gap:5px;margin-bottom:3px;}
.sb-lbl{font-size:8px;color:var(--mut);width:24px;flex-shrink:0;}
.sb-trk{flex:1;height:3px;background:var(--panel2);border-radius:1px;overflow:hidden;}
.sb-fil{height:100%;border-radius:1px;}
.sb-v{font-size:8px;font-family:'Space Mono',monospace;color:var(--txt);width:24px;text-align:right;flex-shrink:0;}

/* overall live update indicator */
.live-pill{position:absolute;top:8px;right:8px;font-family:'Space Mono',monospace;font-size:7px;letter-spacing:1px;padding:2px 6px;background:rgba(0,255,136,.12);color:var(--a2);border:1px solid rgba(0,255,136,.25);border-radius:10px;opacity:0;transition:opacity .3s;pointer-events:none;}
.live-pill.show{opacity:1;}

/* ── WWR VISUAL CONTROL ── */
.wwr-wrap{background:var(--panel2);border:1px solid var(--b);border-radius:2px;padding:9px 10px;margin-bottom:7px;}
.wwr-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.wwr-label{font-size:9px;font-family:'Space Mono',monospace;color:var(--mut);letter-spacing:1px;text-transform:uppercase;}
.wwr-val-box{background:var(--bg);border:1px solid var(--a);padding:3px 8px;display:flex;align-items:baseline;gap:2px;}
.wwr-val-box span:first-child{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--a);line-height:1;transition:color .3s;}
.wwr-pct{font-size:9px;color:var(--mut);}

/* Facade preview strip */
.wwr-facade{height:54px;border:1px solid var(--b);background:#060E1A;overflow:hidden;border-radius:1px;margin-bottom:8px;position:relative;}
.wwr-floors{display:flex;flex-direction:column-reverse;height:100%;width:100%;}
.wwr-floor-row{display:flex;flex:1;border-bottom:1px solid rgba(0,119,170,.45);}
.wwr-floor-row:last-child{border-bottom:none;}
.wwr-spandrel{background:#1A2E3E;flex-shrink:0;}
.wwr-bay{display:flex;flex:1;gap:1px;}
.wwr-glazing{flex:1;transition:background .35s,opacity .35s;}
.wwr-pier{background:#1A2E3E;width:4px;flex-shrink:0;}
.wwr-facade-label{position:absolute;top:2px;right:5px;font-family:'Space Mono',monospace;font-size:7px;color:rgba(0,200,255,.4);letter-spacing:1px;}

/* Slider */
.wwr-slider-row{display:flex;align-items:center;gap:7px;margin-bottom:8px;}
.wwr-tick{font-family:'Space Mono',monospace;font-size:8px;color:var(--mut);flex-shrink:0;}
.wwr-slider{flex:1;-webkit-appearance:none;appearance:none;height:3px;border-radius:2px;outline:none;cursor:pointer;background:var(--b);}
.wwr-slider::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--a);border:2px solid var(--bg);cursor:pointer;box-shadow:0 0 0 1px var(--a);transition:transform .15s;}
.wwr-slider::-webkit-slider-thumb:hover{transform:scale(1.25);}
.wwr-slider::-moz-range-thumb{width:12px;height:12px;border-radius:50%;background:var(--a);border:2px solid var(--bg);cursor:pointer;}

/* Presets */
.wwr-presets{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:8px;}
.wwr-pre{background:var(--bg);border:1px solid var(--b);color:var(--mut);font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.5px;padding:4px 2px;cursor:pointer;text-align:center;line-height:1.5;transition:all .2s;text-transform:uppercase;}
.wwr-pre span{color:rgba(255,255,255,.3);font-size:8px;}
.wwr-pre:hover,.wwr-pre.active{border-color:var(--a);color:var(--a);background:rgba(0,200,255,.07);}
.wwr-pre.active span{color:var(--a);}

/* Live thermal readout */
.wwr-impact{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;}
.wi-row{background:rgba(0,0,0,.3);border:1px solid var(--b);padding:4px 5px;border-radius:1px;}
.wi-row span:first-child{font-size:7px;color:var(--mut);font-family:'Space Mono',monospace;display:block;letter-spacing:.5px;text-transform:uppercase;margin-bottom:2px;}
.wi-val{font-family:'Space Mono',monospace;font-size:9px;color:var(--a);display:block;}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="logo"><div class="logo-dot"></div>METACONNEX</div>
  <div class="proj-tag">B1 · CROMPTON PLACE · S2 OPTION F</div>
  <div class="topbar-right">
    <div class="badge">BTR / RESIDENTIAL</div>
    <div class="badge">6 STOREYS · 18.0M</div>
    <div class="badge gold" id="ntgBadge">NTG 72%</div>
    <div class="badge g" id="statusBadge">LIVE</div>
  </div>
</div>

<!-- MODULE TABS -->
<div class="module-tabs">
  <div class="mtab active" id="tabEnergy" onclick="switchModule('energy')">⚡ Energy & CFD</div>
  <div class="mtab social" id="tabSocial" onclick="switchModule('social')">🌱 Social & Sustainability</div>
</div>

<div class="main">

<!-- ══════════════ LEFT: BUILDING EDITOR ══════════════ -->
<div class="editor" id="editor">
  <div class="esec">
    <div class="esh">B1 Crompton — Live Building Editor</div>
    <div class="calc-note">Edit any field → all outputs update instantly. Bold = derived automatically.</div>
    <div style="height:5px"></div>
