function drawMonthly(m){
  const c=document.getElementById('monthlyChart');c.width=c.offsetWidth*2;c.height=160;
  const ctx=c.getContext('2d'),W=c.width,H=c.height,all=[...m.h,...m.c],mx=Math.max(...all)||1,bw=W/12;
  ctx.clearRect(0,0,W,H);
  ['J','F','M','A','M','J','J','A','S','O','N','D'].forEach((mn,i)=>{
    const hh=(m.h[i]/mx)*(H-24),ch=(m.c[i]/mx)*(H-24);
    ctx.fillStyle='rgba(0,200,255,.7)';ctx.fillRect(i*bw+2,H-hh-16,bw/2-2,hh);
    ctx.fillStyle='rgba(0,255,136,.7)';ctx.fillRect(i*bw+bw/2,H-ch-16,bw/2-2,ch);
    ctx.fillStyle='#5A7A9A';ctx.font='12px Space Mono,monospace';ctx.textAlign='center';ctx.fillText(mn,i*bw+bw/2,H-3);
  });
}

