<script>
const T=5;let c=1;
const de=document.getElementById('dots');
for(let i=1;i<=T;i++){const d=document.createElement('div');d.className='nd'+(i===1?' on':'');d.onclick=()=>go(i);de.appendChild(d);}
function go(n){c=n;document.getElementById('s'+n)?.scrollIntoView({behavior:'smooth',block:'start'});document.querySelectorAll('.nd').forEach((d,i)=>d.classList.toggle('on',i===n-1));document.getElementById('ctr').textContent=n+' / '+T;setTimeout(()=>document.getElementById('s'+n)?.querySelectorAll('.ai').forEach(e=>e.classList.add('v')),120);}
function next(){if(c<T)go(c+1);}function prev(){if(c>1)go(c-1);}
window.addEventListener('keydown',e=>{if(e.key==='ArrowRight'||e.key==='ArrowDown')next();if(e.key==='ArrowLeft'||e.key==='ArrowUp')prev();});
window.addEventListener('scroll',()=>{for(let i=1;i<=T;i++){const s=document.getElementById('s'+i);if(!s)continue;const r=s.getBoundingClientRect();if(r.top<=window.innerHeight/2&&r.bottom>=window.innerHeight/2){if(c!==i){c=i;document.querySelectorAll('.nd').forEach((d,j)=>d.classList.toggle('on',j===i-1));document.getElementById('ctr').textContent=i+' / '+T;}s.querySelectorAll('.ai').forEach(e=>e.classList.add('v'));}}},{passive:true});
setTimeout(()=>document.getElementById('s1')?.querySelectorAll('.ai').forEach(e=>e.classList.add('v')),200);
<\/script></body></html>`;}

