<script>
// ══════════════════════════════════════════════════
// THREE.JS SETUP
// ══════════════════════════════════════════════════
const canvas = document.getElementById('threeCanvas');
const renderer = new THREE.WebGLRenderer({canvas,antialias:true,preserveDrawingBuffer:true});
renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
renderer.shadowMap.enabled=true;renderer.shadowMap.type=THREE.PCFSoftShadowMap;
renderer.toneMapping=THREE.ACESFilmicToneMapping;renderer.toneMappingExposure=1.0;

const scene=new THREE.Scene();scene.background=new THREE.Color(0x040810);
scene.fog=new THREE.FogExp2(0x040810,0.012);
const camera=new THREE.PerspectiveCamera(45,1,0.1,1000);
let theta=0.85,phi=0.82,radius=50;
function posCamera(){camera.position.set(radius*Math.sin(theta)*Math.cos(phi),radius*Math.sin(phi),radius*Math.cos(theta)*Math.cos(phi));camera.lookAt(0,9,0);}
posCamera();

scene.add(new THREE.AmbientLight(0x1a2a4a,1.0));
const sun=new THREE.DirectionalLight(0xAADDFF,2.8);
sun.position.set(35,55,20);sun.castShadow=true;
sun.shadow.mapSize.set(2048,2048);sun.shadow.camera.left=-60;sun.shadow.camera.right=60;
sun.shadow.camera.top=60;sun.shadow.camera.bottom=-60;
scene.add(sun);
scene.add(new THREE.DirectionalLight(0x334466,0.6).position.set(-20,10,-25)&&sun);

scene.add(new THREE.GridHelper(120,48,0x1a2a40,0x0d1520));
const gnd=new THREE.Mesh(new THREE.PlaneGeometry(140,140),new THREE.MeshStandardMaterial({color:0x060D1A,roughness:.95}));
gnd.rotation.x=-Math.PI/2;gnd.receiveShadow=true;scene.add(gnd);

const bGroup=new THREE.Group();scene.add(bGroup);
let bMesh=null,glazeMeshes=[];
const thermalGroup=new THREE.Group();thermalGroup.visible=false;scene.add(thermalGroup);
const pressureGroup=new THREE.Group();pressureGroup.visible=false;scene.add(pressureGroup);

// CFD particles
const CFD=1600;const cfdPos=new Float32Array(CFD*3);const cfdCol=new Float32Array(CFD*3);const cfdSpd=new Float32Array(CFD);
const cfdGeo=new THREE.BufferGeometry();
cfdGeo.setAttribute('position',new THREE.BufferAttribute(cfdPos,3));
cfdGeo.setAttribute('color',new THREE.BufferAttribute(cfdCol,3));
const cfdPts=new THREE.Points(cfdGeo,new THREE.PointsMaterial({size:0.17,vertexColors:true,transparent:true,opacity:0.75,sizeAttenuation:true}));
