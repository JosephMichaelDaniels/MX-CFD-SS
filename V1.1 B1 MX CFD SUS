      if(solPos[i*3+1]<-1||solPos[i*3+2]>26){solPos[i*3]=(Math.random()-.5)*38;solPos[i*3+1]=26+Math.random()*10;solPos[i*3+2]=-26+Math.random()*8;}
      if(solPos[i*3+2]>bZ-.5&&solPos[i*3+2]<bZ+.5&&solPos[i*3+1]<bH2&&Math.abs(solPos[i*3])<vn('length')/2){solCol[i*3]=1;solCol[i*3+1]=.5;solCol[i*3+2]=0;}
    }
    solGeo.attributes.position.needsUpdate=true;solGeo.attributes.color.needsUpdate=true;
  }
  if(dayPts.visible){
    const bH3=bMesh?bMesh.position.y*2:18;
    for(let i=0;i<DAY;i++){
      dayPos[i*3+1]-=.05+Math.random()*.04;
      if(dayPos[i*3+1]<-1){const a=Math.random()*Math.PI*2,r=12+Math.random()*14;dayPos[i*3]=Math.cos(a)*r;dayPos[i*3+1]=20+Math.random()*8;dayPos[i*3+2]=Math.sin(a)*r;dayCol[i*3]=.5+Math.random()*.5;dayCol[i*3+1]=.8+Math.random()*.2;dayCol[i*3+2]=1;}
      if(Math.abs(dayPos[i*3])<vn('length')/2+1&&Math.abs(dayPos[i*3+2])<vn('depth')/2+1&&dayPos[i*3+1]<bH3+1){dayCol[i*3]=.9;dayCol[i*3+1]=.85;dayCol[i*3+2]=.6;}
    }
    dayGeo.attributes.position.needsUpdate=true;dayGeo.attributes.color.needsUpdate=true;
  }
  renderer.render(scene,camera);
}
