function runSim(){
  buildBuilding();buildThermal();buildPressure();
  const ov=document.getElementById('simOv');ov.classList.add('on');
  document.getElementById('statusBadge').textContent='RUNNING';document.getElementById('statusBadge').className='badge o';
  document.getElementById('runBtn').disabled=true;
  const steps=['Parsing B1 building geometry...','Computing fabric heat loss (EN ISO 13790)...','Calculating solar gains...','Running CFD wind pressure (ASCE 7-22)...','HVAC peak load calculations...','Annual 8760-hr simulation...','Computing social & value metrics...','Building visual overlays...'];
  const phases=['GEOM','FABRIC','SOLAR','CFD','HVAC','ENERGY','SOCIAL','VISUAL'];
  let st=0;
  const iv=setInterval(()=>{
    if(st>=steps.length){clearInterval(iv);
      R=compute();simDone=true;
      buildThermal();buildPressure();
      renderEnergyResults(R);renderSocialResults(R);
      ov.classList.remove('on');
      document.getElementById('statusBadge').textContent='LIVE';document.getElementById('statusBadge').className='badge g';
      document.getElementById('runBtn').disabled=false;
      applyMode(curMode);return;}
    const pct=Math.round(st/steps.length*100);
    document.getElementById('pf').style.width=pct+'%';
    document.getElementById('ppct').textContent=pct+'%';
    document.getElementById('simStepTxt').textContent=steps[st];
    document.getElementById('pphase').textContent=phases[st]||'';
    st++;
  },380);
}

