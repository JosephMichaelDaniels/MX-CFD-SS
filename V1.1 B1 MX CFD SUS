// WWR VISUAL CONTROL
// ══════════════════════════════════════════════════
function onWWRChange(val){
  val = Math.round(val);
  document.getElementById('wwrDisplay').textContent = val;

  // Colour-code the value: blue→yellow→red as glass increases
  const t = (val - 20) / 80; // 0 at 20%, 1 at 100%
  const col = t < 0.4
    ? `hsl(${200 - t*200},90%,60%)`   // blue→cyan
    : t < 0.7
    ? `hsl(${120 - (t-0.4)*400},90%,60%)`  // cyan→yellow
    : `hsl(${Math.max(0,40-(t-0.7)*133)},90%,60%)`; // yellow→red
  document.getElementById('wwrDisplay').style.color = col;
  document.querySelector('.wwr-val-box').style.borderColor = col;
  document.querySelector('.wwr-slider').style.background =
    `linear-gradient(to right, ${col} 0%, ${col} ${((val-20)/80)*100}%, var(--b) ${((val-20)/80)*100}%, var(--b) 100%)`;

  // Update preset button active state
  document.querySelectorAll('.wwr-pre').forEach(btn => btn.classList.remove('active'));
  if(val===25) document.querySelectorAll('.wwr-pre')[0].classList.add('active');
  else if(val===40) document.querySelectorAll('.wwr-pre')[1].classList.add('active');
  else if(val===60) document.querySelectorAll('.wwr-pre')[2].classList.add('active');
  else if(val===100) document.querySelectorAll('.wwr-pre')[3].classList.add('active');

  renderWWRFacade(val);
  updateWWRImpact(val);
  liveUpdate();
}

function setWWR(val){
  document.getElementById('glazPct').value = val;
  onWWRChange(val);
}

function renderWWRFacade(pct){
  const container = document.getElementById('wwrFloors');
  const stor = Math.max(1, vn('storeys'));
  const nBays = 6;
  const wRatio = pct / 100;
  const sRatio = 1 - wRatio;

  // Colour for glazing tiles: more glass = more blue/reflective
  const glassR = Math.round(80 + (1-wRatio)*60);
  const glassG = Math.round(160 + wRatio*30);
  const glassB = Math.round(220);
  const glassAlpha = 0.35 + wRatio * 0.55;
  const glassCol = `rgba(${glassR},${glassG},${glassB},${glassAlpha})`;
  const spandrelCol = `#1C2E3E`;
  const pierCol = `#162434`;
  const frameCol = `rgba(80,120,140,0.5)`;

  let html = '';
  for(let f = 0; f < stor; f++){
    const isGF = (f === 0);
    const floorH = isGF ? 1.5 : 1; // GF taller in preview
    const spH = Math.max(6, Math.round(sRatio * 100 * (isGF ? 0.35 : 0.4)));
    const wH = 100 - spH;

    html += `<div class="wwr-floor-row" style="flex:${floorH}">`;

    // Spandrel band at base of each floor
    html += `<div style="position:absolute;left:0;right:0;height:${spH*0.55}%;background:${spandrelCol};bottom:0;"></div>`;

    // Build bays
    html += `<div style="display:flex;width:100%;height:100%;position:relative;">`;
    // Top spandrel / lintel
    html += `<div style="position:absolute;top:0;left:0;right:0;height:${Math.max(4, spH*0.5)}%;background:${spandrelCol};z-index:2;"></div>`;
    // Bottom sill
    html += `<div style="position:absolute;bottom:0;left:0;right:0;height:${Math.max(4, spH*0.5)}%;background:${spandrelCol};z-index:2;"></div>`;

    for(let bay = 0; bay < nBays; bay++){
      const isCoreZone = (bay===1 || bay===4);
      html += `<div style="flex:1;display:flex;align-items:stretch;position:relative;">`;
      // Vertical pier
      html += `<div style="width:3px;background:${pierCol};flex-shrink:0;z-index:3;"></div>`;
      // Window or solid wall
      if(isCoreZone || wRatio < 0.05){
        html += `<div style="flex:1;background:${spandrelCol};"></div>`;
      } else {
        // Glazed area (clipped between spandrel bands)
        html += `<div style="flex:1;background:${glassCol};background-image:linear-gradient(135deg,rgba(255,255,255,0.08) 0%,transparent 50%,rgba(0,0,0,0.04) 100%);border-left:1px solid ${frameCol};border-right:1px solid ${frameCol};"></div>`;
      }
      html += `</div>`;
    }
    // Last pier
    html += `<div style="width:3px;background:${pierCol};z-index:3;"></div>`;
    html += `</div>`; // bay row
    html += `</div>`; // floor row
  }

  container.innerHTML = html;

  // Label
  const label = pct <= 30 ? 'TRADITIONAL'
    : pct <= 50 ? 'MID-RANGE'
    : pct <= 75 ? 'CONTEMPORARY'
    : 'CURTAIN WALL';
  const facadeEl = document.getElementById('wwrFacade');
  let lbl = facadeEl.querySelector('.wwr-facade-label');
  if(!lbl){ lbl = document.createElement('div'); lbl.className='wwr-facade-label'; facadeEl.appendChild(lbl); }
  lbl.textContent = label + ' · ' + pct + '% WWR';
}

function updateWWRImpact(pct){
  const gia = vn('gia') || 5973;
  const len = vn('length') || 48;
  const dep = vn('depth') || 18;
  const stor = vn('storeys') || 6;
